# =============================================================================
# IdeaXchange - Environment Variables for Render.com Deployment
# =============================================================================
# Copy this file to .env for local development (never commit .env to git!)
# On Render: add each key under "Environment" > "Environment Variables"

# -----------------------------------------------------------------------------
# SERVER CORE
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=production
NODE_ID=render-node-1

# -----------------------------------------------------------------------------
# MONGODB (required — core database)
# Get your connection string from MongoDB Atlas: https://cloud.mongodb.com
# -----------------------------------------------------------------------------
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ideaxchange?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# FIREBASE / FIRESTORE (required — FATAL if missing or invalid)
# 1. Go to Firebase Console > Project Settings > Service Accounts
# 2. Click "Generate new private key" to download the JSON
# 3. Paste the entire JSON content as a single line into FIREBASE_SERVICE_ACCOUNT_KEY
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_ID=(default)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# -----------------------------------------------------------------------------
# REDIS (optional for demo — falls back to in-memory rate limiting if missing)
# Free Redis: https://upstash.com  (provides a redis:// URL with auth)
# -----------------------------------------------------------------------------
REDIS_URL=redis://default:<password>@<host>:<port>

# -----------------------------------------------------------------------------
# AUTH / SECURITY (required — WARN if missing, some features disabled)
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=your-secure-jwt-secret-minimum-32-characters-long
PLATFORM_SIGNING_KEY=your-secure-platform-signing-key-minimum-32-chars
RAFT_INTERNAL_SECRET=your-secure-raft-internal-secret-minimum-32-chars

# -----------------------------------------------------------------------------
# CORS (set to your Render service URL, or comma-separated list)
# Example: https://your-app.onrender.com
# If frontend and backend are the SAME service, set to the service URL.
# If separate services: https://frontend.onrender.com,https://custom-domain.com
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://your-app.onrender.com

# -----------------------------------------------------------------------------
# GOOGLE OAUTH (optional — WARN if missing, OAuth login disabled)
# Get from: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
OAUTH_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# -----------------------------------------------------------------------------
# GOOGLE GEMINI AI (optional — WARN if missing, AI features disabled)
# Get from: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=AIza-your-gemini-api-key

# -----------------------------------------------------------------------------
# SECURITY POLICIES (optional)
# -----------------------------------------------------------------------------
COOKIE_DOMAIN=your-app.onrender.com
KEY_VERSION=v1
